   "scripts": {
      "start": "BROWSER=none PORT=3001 react-scripts --max-http-header-size=65535 start",
      "dev": "npm start",
      "build": "react-scripts build",
      "prebuild": "npm run type-check",
      "test": "react-scripts test",
      "test:ci": "react-scripts test --coverage --watchAll=false --passWithNoTests",
      "test:coverage": "react-scripts test --coverage",
      "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
      "lint:fix": "eslint src --ext .ts,.tsx --fix",
      "type-check": "tsc --noEmit",
      "clean": "rm -rf node_modules/ && rm -rf lib/ && rm -rf build/",
      "clean:deps": "rm -rf node_modules/ && rm -rf package-lock.json",
      "install:legacy": "npm install --legacy-peer-deps && npm dedupe --force",
      "prepare": "npm run type-check",
      "prepublishOnly": "npm run build && tsc -p ./ --outDir lib/",
      "eject": "react-scripts eject"
   },
   "eslintConfig": {
      "extends": [
         "react-app",
         "react-app/jest"
      ]
   },
   "browserslist": {
      "production": [
         ">0.2%",
         "not dead",
         "not op_mini all"
      ],
      "development": [
         "last 1 chrome version",
         "last 1 firefox version",
         "last 1 safari version"
      ]
   },
   "publishConfig": {
      "registry": "https://registry.npmjs.org/"
   },
   "devDependencies": {
      "@babel/plugin-proposal-private-property-in-object": "7.21.11",
      "@svgr/webpack": "6.5.1",
      "@types/chroma-js": "2.1.3",
      "@types/faker": "5.5.9",
      "@types/react-table": "7.7.9",
      "@typescript-eslint/eslint-plugin": "5.10.2",
      "@typescript-eslint/parser": "5.10.2",
      "eslint": "8.8.0",
      "eslint-import-resolver-typescript": "2.5.0",
      "eslint-plugin-import": "2.25.4",
      "eslint-plugin-react": "7.28.0",
      "react-scripts": "5.0.1",
      "typescript": "4.9.4"
   },
   "overrides": {
      "@svgr/webpack": "$@svgr/webpack"
   },
   "main": "qqq-frontend-material-dashboard.js",
   "module": "lib/qqq-frontend-material-dashboard.js",
   "files": [
      "lib",
      "package.json"
   ]
